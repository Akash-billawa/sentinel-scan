# =====================================================================
# SentinelScan AI — environment configuration
# Copy this file to `.env` and fill in real values to enable features.
# =====================================================================

# --- Server ---
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=5000
SENTINEL_SECRET_KEY=change-me-to-a-long-random-string

# Public URL the dashboard (and Slack/webhook links) point back to.
# Set this in production so the Slack ack button and "open dashboard"
# link resolve to the right host.  Default is fine for local dev.
SENTINEL_PUBLIC_URL=http://localhost:5000

# Number of trusted reverse proxies in front of the application.
# Set to 1 if behind a single reverse proxy (e.g. Nginx, Cloudflare, ngrok)
# so rate-limiting and logs use the client IP instead of 127.0.0.1.
SENTINEL_PROXY_FIX_COUNT=0

# --- Capture mode ---
# auto   : use Scapy if available, otherwise simulation
# live   : require Scapy/Npcap; fail if unavailable
# sim    : always run in simulation mode (no raw capture required)
SENTINEL_CAPTURE_MODE=auto

# Network interface to listen on (Windows: 'Ethernet', 'Wi-Fi'; Linux: 'eth0')
SENTINEL_INTERFACE=

# --- Database ---
SENTINEL_DB_URL=sqlite:///data/sentinelscan.db

# --- Detection tuning ---
# Time window in seconds for rate-based detection
SENTINEL_WINDOW_SECONDS=15
# Port sweep threshold (unique destination ports per source)
SENTINEL_PORTSWEEP_THRESHOLD=20
# Host sweep threshold (unique destination hosts per source)
SENTINEL_HOSTSWEEP_THRESHOLD=15
# Packet-rate threshold per source per window
SENTINEL_RATE_THRESHOLD=200

# --- Alerts ---
# Master switch
SENTINEL_ALERTS_ENABLED=true
# Cooldown in seconds for repeat alerts from the same source
SENTINEL_ALERT_COOLDOWN=120
# Minimum risk level to trigger alerts: low, medium, high, critical
SENTINEL_ALERT_MIN_LEVEL=low

# Desktop notifications (Windows/macOS/Linux)
SENTINEL_DESKTOP_ALERTS=true

# Email (SMTP)
SENTINEL_EMAIL_ENABLED=false
SENTINEL_SMTP_HOST=smtp.gmail.com
SENTINEL_SMTP_PORT=587
SENTINEL_SMTP_USER=
SENTINEL_SMTP_PASSWORD=
SENTINEL_SMTP_FROM=
SENTINEL_SMTP_TO=

# Telegram
SENTINEL_TELEGRAM_ENABLED=false
SENTINEL_TELEGRAM_BOT_TOKEN=
SENTINEL_TELEGRAM_CHAT_ID=
# Optional: Use a Telegram reverse proxy/custom gateway if api.telegram.org is blocked
# SENTINEL_TELEGRAM_BASE_URL=https://api.telegram.org
# Enable Telegram webhook mode (instead of long polling)
SENTINEL_TELEGRAM_WEBHOOK_ENABLED=false
# The public URL configured on the reverse proxy that Telegram hits (reverse-proxy hint)
SENTINEL_TELEGRAM_WEBHOOK_URL=http://localhost:5000

# --- Network Proxies ---
# If your environment requires an HTTP/HTTPS proxy to reach external APIs
# (Telegram), set them here. The requests library will pick these up
# automatically.
# HTTP_PROXY=http://10.10.1.10:3128
# HTTPS_PROXY=http://10.10.1.10:1080

# --- Authentication ---
# Set to false to disable auth (local dev only).
SENTINEL_AUTH_ENABLED=true
# Default admin user.  The first-run password is auto-generated and printed
# to the server log if SENTINEL_ADMIN_PASSWORD is left empty.
SENTINEL_ADMIN_USER=admin
SENTINEL_ADMIN_PASSWORD=
# Session lifetime in hours.
SENTINEL_AUTH_SESSION_HOURS=12

# --- Encrypted log storage ---
# Encrypt sensitive fields (source IP, MAC, target ports/hosts, technique
# signals) at rest.  Key is derived from SENTINEL_SECRET_KEY via PBKDF2.
SENTINEL_ENCRYPT_LOGS=false
# Optional salt override; if empty, derived from SENTINEL_SECRET_KEY.
SENTINEL_ENCRYPTION_SALT=

# --- IPS (Intrusion Prevention System) ---
# Enable IPS functionality
SENTINEL_IPS_ENABLED=false
# IPS mode: approve (manual review), auto_block (block high risk), alert_only (log only)
SENTINEL_IPS_MODE=approve
# Seconds to wait for operator response before expiring
SENTINEL_IPS_APPROVAL_TIMEOUT=60
# Risk score >= this triggers auto-block (default: 8.0)
SENTINEL_IPS_AUTO_BLOCK_THRESHOLD=8.0
# Risk score >= this requires approval (default: 4.0)
SENTINEL_IPS_APPROVAL_THRESHOLD=4.0
# Seconds until blocked IP is automatically unblocked (0 = never expire)
SENTINEL_IPS_BLOCK_EXPIRY=0
# Re-apply all firewall rules from DB on boot (default: true)
SENTINEL_IPS_REAPPLY_ON_BOOT=true

# --- Threat Intelligence (AbuseIPDB) ---
# Enable enrichment of detected attacks with AbuseIPDB reputation data.
# When an IP has abuseConfidenceScore >= 50, the attack risk score is
# boosted by +1.0 (up to 10.0).
SENTINEL_THREAT_INTEL_ENABLED=false
# Your AbuseIPDB API key (v2).  Get one at https://www.abuseipdb.com/api
SENTINEL_THREAT_INTEL_API_KEY=
# AbuseIPDB API base URL (change only for self-hosted or mirror).
SENTINEL_THREAT_INTEL_API_URL=https://api.abuseipdb.com
# Max age of reports to consider, in days (default: 30).
SENTINEL_THREAT_INTEL_MAX_AGE=30
